<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thông báo đăng nhập</title>
  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f3f4f6;
      font-family: Arial, sans-serif;
      color: #111827;
    "
  >
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      style="padding: 40px 16px"
    >
      <tr>
        <td align="center">
          <!-- Container -->
          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            style="
              width: 100%;
              max-width: 600px;
              background: #ffffff;
              border-radius: 18px;
              overflow: hidden;
              border: 1px solid #e5e7eb;
            "
          >
            <!-- Header -->
            <tr>
              <td
                align="center"
                style="background: #2563eb; padding: 40px 30px"
              >
                <div
                  style="
                    width: 60px;
                    height: 60px;
                    line-height: 60px;
                    border-radius: 14px;
                    background: rgba(255, 255, 255, 0.15);
                    color: white;
                    font-size: 26px;
                    font-weight: bold;
                    margin-bottom: 18px;
                  "
                >
                  E
                </div>

                <h1
                  style="
                    margin: 0;
                    color: white;
                    font-size: 28px;
                    font-weight: 700;
                  "
                >
                  Ecommerce
                </h1>

                <p style="margin: 10px 0 0; color: #dbeafe; font-size: 14px">
                  Thông báo bảo mật tài khoản
                </p>
              </td>
            </tr>

            <!-- Content -->
            <tr>
              <td style="padding: 40px 32px">
                <p style="margin: 0; color: #6b7280; font-size: 15px">
                  Xin chào,
                </p>

                <h2 style="margin: 8px 0 24px; font-size: 28px; color: #111827">
                  <%= name %>
                </h2>

                <p
                  style="
                    margin: 0;
                    color: #4b5563;
                    font-size: 15px;
                    line-height: 1.8;
                  "
                >
                  Tài khoản của bạn vừa đăng nhập thành công vào hệ thống
                  Ecommerce.
                </p>

                <!-- Info -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  style="
                    margin-top: 28px;
                    background: #f9fafb;
                    border: 1px solid #e5e7eb;
                    border-radius: 14px;
                  "
                >
                  <tr>
                    <td style="padding: 22px">
                      <p style="margin: 0; color: #6b7280; font-size: 13px">
                        Thời gian đăng nhập
                      </p>

                      <p
                        style="
                          margin: 8px 0 0;
                          font-size: 20px;
                          font-weight: bold;
                          color: #111827;
                        "
                      >
                        <%= time %>
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- Warning -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  style="
                    margin-top: 24px;
                    background: #eff6ff;
                    border: 1px solid #bfdbfe;
                    border-radius: 14px;
                  "
                >
                  <tr>
                    <td style="padding: 20px">
                      <p
                        style="
                          margin: 0;
                          color: #1e40af;
                          font-size: 14px;
                          line-height: 1.8;
                        "
                      >
                        Nếu đây không phải là bạn, hãy đổi mật khẩu ngay để bảo
                        vệ tài khoản.
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- Button -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  style="margin-top: 34px"
                >
                  <tr>
                    <td align="center">
                      <a
                        href="#"
                        style="
                          display: inline-block;
                          background: #2563eb;
                          color: white;
                          text-decoration: none;
                          padding: 14px 28px;
                          border-radius: 10px;
                          font-size: 15px;
                          font-weight: bold;
                        "
                      >
                        Đổi mật khẩu
                      </a>
                    </td>
                  </tr>
                </table>

                <!-- Footer text -->
                <p
                  style="
                    margin: 36px 0 0;
                    text-align: center;
                    color: #9ca3af;
                    font-size: 13px;
                    line-height: 1.7;
                  "
                >
                  Đây là email tự động từ hệ thống Ecommerce.<br />
                  Vui lòng không phản hồi email này.
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                align="center"
                style="
                  background: #f9fafb;
                  border-top: 1px solid #e5e7eb;
                  padding: 24px;
                "
              >
                <p style="margin: 0; color: #6b7280; font-size: 13px">
                  © 2026 Ecommerce. All rights reserved.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
