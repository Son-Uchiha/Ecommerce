<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Security Login Alert</title>
  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      background: #eef2ff;
      font-family: 'Segoe UI', Arial, sans-serif;
      color: #111827;
    "
  >
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      border="0"
      style="padding: 50px 20px"
    >
      <tr>
        <td align="center">
          <!-- Main Container -->
          <table
            width="640"
            cellpadding="0"
            cellspacing="0"
            border="0"
            style="
              width: 100%;
              max-width: 640px;
              background: #ffffff;
              border-radius: 24px;
              overflow: hidden;
              box-shadow:
                0 20px 40px rgba(15, 23, 42, 0.08),
                0 4px 12px rgba(15, 23, 42, 0.05);
            "
          >
            <!-- Top Accent -->
            <tr>
              <td
                style="
                  height: 6px;
                  background: linear-gradient(90deg, #2563eb, #4f46e5, #7c3aed);
                "
              ></td>
            </tr>

            <!-- Header -->
            <tr>
              <td
                style="
                  background:
                    radial-gradient(
                      circle at top left,
                      rgba(255, 255, 255, 0.08),
                      transparent 30%
                    ),
                    linear-gradient(135deg, #0f172a, #1e3a8a);
                  padding: 48px 42px;
                  text-align: center;
                "
              >
                <!-- Logo -->
                <div
                  style="
                    width: 72px;
                    height: 72px;
                    margin: 0 auto 22px;
                    background: rgba(255, 255, 255, 0.12);
                    border: 1px solid rgba(255, 255, 255, 0.15);
                    border-radius: 20px;
                    line-height: 72px;
                    font-size: 30px;
                    color: white;
                    font-weight: bold;
                    backdrop-filter: blur(10px);
                  "
                >
                  E
                </div>

                <h1
                  style="
                    margin: 0;
                    color: #ffffff;
                    font-size: 34px;
                    font-weight: 700;
                    letter-spacing: 0.4px;
                  "
                >
                  Ecommerce
                </h1>

                <p
                  style="
                    margin: 12px 0 0;
                    color: #cbd5e1;
                    font-size: 15px;
                    line-height: 1.7;
                  "
                >
                  Secure Login Notification
                </p>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding: 46px 42px">
                <!-- Greeting -->
                <p
                  style="
                    margin: 0;
                    font-size: 15px;
                    color: #64748b;
                    line-height: 1.8;
                  "
                >
                  Xin chào,
                </p>

                <h2
                  style="
                    margin: 8px 0 24px;
                    font-size: 32px;
                    font-weight: 700;
                    color: #0f172a;
                    letter-spacing: -0.5px;
                  "
                >
                  <%= name %>
                </h2>

                <p
                  style="
                    margin: 0;
                    font-size: 15px;
                    line-height: 1.9;
                    color: #475569;
                  "
                >
                  Chúng tôi ghi nhận tài khoản của bạn vừa đăng nhập thành công
                  vào hệ thống Ecommerce.
                </p>

                <!-- Info Card -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  style="
                    margin-top: 34px;
                    background: linear-gradient(135deg, #f8fafc, #f1f5f9);
                    border: 1px solid #e2e8f0;
                    border-radius: 18px;
                  "
                >
                  <tr>
                    <td style="padding: 28px">
                      <p
                        style="
                          margin: 0 0 12px;
                          font-size: 12px;
                          font-weight: 700;
                          color: #64748b;
                          letter-spacing: 1px;
                          text-transform: uppercase;
                        "
                      >
                        Thời gian đăng nhập
                      </p>

                      <p
                        style="
                          margin: 0;
                          font-size: 20px;
                          font-weight: 700;
                          color: #0f172a;
                        "
                      >
                        <%= time %>
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- Security Warning -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  style="
                    margin-top: 26px;
                    background: linear-gradient(135deg, #eff6ff, #dbeafe);
                    border: 1px solid #bfdbfe;
                    border-radius: 18px;
                  "
                >
                  <tr>
                    <td style="padding: 24px">
                      <table
                        width="100%"
                        cellpadding="0"
                        cellspacing="0"
                        border="0"
                      >
                        <tr>
                          <!-- Icon -->
                          <td width="52" valign="top">
                            <div
                              style="
                                width: 42px;
                                height: 42px;
                                background: #2563eb;
                                border-radius: 12px;
                                text-align: center;
                                line-height: 42px;
                                color: white;
                                font-size: 18px;
                                font-weight: bold;
                              "
                            >
                              !
                            </div>
                          </td>

                          <!-- Text -->
                          <td valign="top">
                            <p
                              style="
                                margin: 0;
                                color: #1e3a8a;
                                font-size: 14px;
                                line-height: 1.9;
                              "
                            >
                              Nếu đây không phải là bạn, hãy đổi mật khẩu ngay
                              lập tức để bảo vệ tài khoản và liên hệ đội ngũ hỗ
                              trợ khách hàng.
                            </p>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- Button -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  style="margin-top: 38px"
                >
                  <tr>
                    <td align="center">
                      <a
                        href="#"
                        style="
                          display: inline-block;
                          background: linear-gradient(135deg, #2563eb, #4f46e5);
                          color: #ffffff;
                          text-decoration: none;
                          padding: 16px 34px;
                          border-radius: 14px;
                          font-size: 15px;
                          font-weight: 700;
                          letter-spacing: 0.3px;
                          box-shadow: 0 10px 20px rgba(37, 99, 235, 0.25);
                        "
                      >
                        Đổi mật khẩu ngay
                      </a>
                    </td>
                  </tr>
                </table>

                <!-- Divider -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  style="margin-top: 42px"
                >
                  <tr>
                    <td
                      style="
                        border-top: 1px solid #e2e8f0;
                        font-size: 0;
                        line-height: 0;
                      "
                    >
                      &nbsp;
                    </td>
                  </tr>
                </table>

                <!-- Footer Text -->
                <p
                  style="
                    margin: 28px 0 0;
                    text-align: center;
                    font-size: 13px;
                    color: #94a3b8;
                    line-height: 1.8;
                  "
                >
                  Đây là email tự động từ hệ thống bảo mật Ecommerce.<br />
                  Vui lòng không phản hồi email này.
                </p>
              </td>
            </tr>

            <!-- Bottom Footer -->
            <tr>
              <td
                style="
                  background: #f8fafc;
                  border-top: 1px solid #e2e8f0;
                  padding: 30px;
                  text-align: center;
                "
              >
                <p
                  style="
                    margin: 0;
                    color: #64748b;
                    font-size: 13px;
                    font-weight: 600;
                  "
                >
                  © 2026 Ecommerce. All rights reserved.
                </p>

                <p
                  style="
                    margin: 10px 0 0;
                    color: #94a3b8;
                    font-size: 12px;
                    letter-spacing: 0.5px;
                  "
                >
                  Secure • Reliable • Modern Commerce Platform
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
