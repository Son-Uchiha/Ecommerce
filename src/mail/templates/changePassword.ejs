<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <title>Đổi mật khẩu thành công</title>
  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f4f7fb;
      font-family: Arial, sans-serif;
    "
  >
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center" style="padding: 40px 20px">
          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            style="
              background: #ffffff;
              border-radius: 16px;
              overflow: hidden;
              box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            "
          >
            <!-- Header -->
            <tr>
              <td
                align="center"
                style="
                  background: linear-gradient(135deg, #2563eb, #1e40af);
                  padding: 32px;
                  color: white;
                "
              >
                <h1 style="margin: 0; font-size: 28px">Ecommerce</h1>

                <p style="margin-top: 10px; font-size: 15px; opacity: 0.9">
                  Thông báo bảo mật tài khoản
                </p>
              </td>
            </tr>

            <!-- Content -->
            <tr>
              <td style="padding: 40px 35px">
                <h2 style="margin-top: 0; color: #111827; font-size: 24px">
                  Đổi mật khẩu thành công
                </h2>

                <p style="color: #4b5563; font-size: 16px; line-height: 1.7">
                  Xin chào,
                </p>

                <p style="color: #4b5563; font-size: 16px; line-height: 1.7">
                  Mật khẩu tài khoản Ecommerce của bạn đã được thay đổi thành
                  công.
                </p>

                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  style="
                    background: #f9fafb;
                    border: 1px solid #e5e7eb;
                    border-radius: 12px;
                    margin: 24px 0;
                  "
                >
                  <tr>
                    <td style="padding: 18px">
                      <p style="margin: 0; font-size: 15px; color: #374151">
                        <strong>Email:</strong>
                        <%= email %>
                      </p>
                    </td>
                  </tr>
                </table>

                <p style="color: #dc2626; font-size: 15px; line-height: 1.7">
                  Nếu bạn không thực hiện thay đổi này, hãy liên hệ bộ phận hỗ
                  trợ ngay lập tức để bảo vệ tài khoản của bạn.
                </p>

                <div style="margin-top: 32px">
                  <a
                    href="#"
                    style="
                      display: inline-block;
                      padding: 14px 28px;
                      background: #2563eb;
                      color: white;
                      text-decoration: none;
                      border-radius: 10px;
                      font-weight: bold;
                      font-size: 15px;
                    "
                  >
                    Truy cập hệ thống
                  </a>
                </div>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                align="center"
                style="
                  padding: 24px;
                  background: #f9fafb;
                  color: #9ca3af;
                  font-size: 13px;
                "
              >
                © 2026 Ecommerce. All rights reserved.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
